{
  "name": "gantt",
  "private": true,
  "version": "0.2.1",
  "type": "module",
  "scripts": {
    "dev": "bun scripts/dev.ts",
    "dev:client": "vite",
    "predev:server": "bash -c 'kill -9 $(lsof -ti :${PORT:-3001}) 2>/dev/null; true'",
