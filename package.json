    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5",
    "autoprefixer": "^10.5.0",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "lucide-react": "^1.16.0",
    "motion": "^12.38.0",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "postcss": "^8.5.14",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
