# GitHub OAuth App credentials
# Create at: github.com/settings/developers → OAuth Apps
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Secret for signing session cookies (minimum 32 chars, random)
SESSION_SECRET=

# Bun server port
PORT=3000

# Public app URL (no trailing slash)
# Dev: http://localhost:5173
# Prod: https://gantt.eternum.lat
VITE_APP_URL=http://localhost:5173
